# VELTRIX API Configuration
# Generated for local development with SQLite fallback

# Environment
ENV=development
APP_NAME="Veltrix API"

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRES_MIN=15
REFRESH_EXPIRES_DAYS=14

# Database Configuration
# SQLite for local development (no external dependency)
DATABASE_URL=sqlite:///./veltrix.db

# Redis Configuration (optional for local dev)
# Leave commented out to test without Redis, or set to local instance
REDIS_URL=redis://localhost:6379

# Frontend URL (for CORS)
# Note: Next.js dev server runs on localhost:3000 by default
FRONTEND_URL=http://localhost:3000

# Cookie Configuration
ACCESS_COOKIE_NAME=veltrix_access
REFRESH_COOKIE_NAME=veltrix_refresh

# Rate Limiting
REQUEST_RATE_LIMIT=180

# Supabase Configuration (optional)
# SUPABASE_URL=
# SUPABASE_KEY=

# ==================================================
# MARKET DATA PROVIDERS
# ==================================================

# AlphaVantage (primary OHLC source)
ALPHAVANTAGE_API_KEY=K2XQ6TY6LUAVBKR2
ALPHAVANTAGE_BASE_URL=https://www.alphavantage.co/query

# Finnhub (quotes & news)
FINNHUB_API_KEY=d80bld1r01qq9ln39cogd80bld1r01qq9ln39cp0

# Polygon.io (enterprise market data)
POLYGON_API_KEY=zJD4tSSuWQ7Evu4_AHdzdTQeK6TQDSu9

# RapidAPI AlphaVantage Proxy (alternative rate-limit strategy)
RAPIDAPI_KEY=aadac6ca16mshcd4abf04c041e9cp1ffaddjsn7482a384a03a
RAPIDAPI_HOST=alpha-vantage.p.rapidapi.com

# ==================================================
# AI / LLM PROVIDERS
# ==================================================

# Google Gemini (primary LLM for copilot)
GEMINI_API_KEY=AIzaSyA2fVfyc8P0rP3nK8QiLtAY5iT7goZkT_8
GEMINI_MODEL=gemini-2.0-flash

# OpenAI (optional fallback)
OPENAI_API_KEY=

# ==================================================
# CACHING & RATE LIMITS
# ==================================================

# Cache TTL (seconds)
OHLC_CACHE_TTL=300
QUOTE_CACHE_TTL=60

# Requests per minute per provider
ALPHAVANTAGE_RPM=5
FINNHUB_RPM=100
POLYGON_RPM=100

# ==================================================
# FEATURE FLAGS
# ==================================================

ENABLE_LIVE_MARKET_DATA=true
ENABLE_SIGNALS_ENGINE=true
ENABLE_COPILOT=true
ENABLE_ML_INFERENCE=true
ENABLE_FALLBACK_DATA=true
