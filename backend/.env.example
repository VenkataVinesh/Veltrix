APP_NAME=Veltrix API
ENV=development
JWT_SECRET=change-me
JWT_ALGORITHM=HS256
JWT_EXPIRES_MIN=15
ACCESS_EXPIRES_MIN=15
REFRESH_EXPIRES_DAYS=14
DATABASE_URL=sqlite:///./veltrix.db
REDIS_URL=
FRONTEND_URL=http://localhost:3001
REQUEST_RATE_LIMIT=180
SEED_DEFAULT_USERS=true
SUPABASE_URL=
SUPABASE_KEY=

# Market data providers
ALPHAVANTAGE_API_KEY=
ALPHAVANTAGE_BASE_URL=https://www.alphavantage.co/query
FINNHUB_API_KEY=
POLYGON_API_KEY=
RAPIDAPI_KEY=
RAPIDAPI_HOST=alpha-vantage.p.rapidapi.com

# AI providers
OPENAI_API_KEY=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Cache and fallback behavior
OHLC_CACHE_TTL=300
QUOTE_CACHE_TTL=60
ENABLE_LIVE_MARKET_DATA=true
ENABLE_SIGNALS_ENGINE=true
ENABLE_COPILOT=true
ENABLE_ML_INFERENCE=true
ENABLE_FALLBACK_DATA=true
